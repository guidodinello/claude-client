{
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Edit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "uv run --project /home/guido/projects/claude-client ruff check --fix \"$CLAUDE_TOOL_INPUT_FILE_PATH\" 2>/dev/null || true"
                    }
                ]
            }
        ],
        "PreToolUse": [
            {
                "matcher": "Edit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "if echo \"$CLAUDE_TOOL_INPUT_FILE_PATH\" | grep -qE '\\.env$'; then echo 'Blocked: do not edit .env files' >&2; exit 1; fi"
                    },
                    {
                        "type": "command",
                        "command": "echo $CLAUDE_TOOL_INPUT_FILE_PATH | grep -q 'uv\\.lock' && echo 'Blocked: edit uv.lock via uv commands, not directly' && exit 1 || exit 0"
                    }
                ]
            }
        ]
    }
}
